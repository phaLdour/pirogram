# --- Database (Neon) ---
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# --- Redis (Upstash) ---
UPSTASH_REDIS_REST_URL="https://<region>.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# --- GitHub OAuth (NextAuth provider) ---
GITHUB_ID=""
GITHUB_SECRET=""

# --- Webhook signing ---
# WEBHOOK_SIGNING_SECRET is a fallback signing secret read from the environment.
# In production prefer DB-stored keys generated from the Settings UI; this env
# var is useful for local dev and migrations.
WEBHOOK_SIGNING_SECRET="generate-with: openssl rand -hex 32"

# Master key used to AES-256-GCM encrypt webhook signing secrets at rest in the
# database. 32 bytes / 64 hex chars. Rotation invalidates all DB-stored keys.
WEBHOOK_KEY_ENCRYPTION_KEY="generate-with: openssl rand -hex 32"

# --- Anthropic API (optional, enables "Drive Sprint with Claude") ---
# Without this, the "Enable Claude on this sprint" button on the sprint page
# returns a friendly "not configured" error and nothing else changes.
ANTHROPIC_API_KEY=""
