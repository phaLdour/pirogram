// AgentWatch — schema
// Initial migration lands in Sprint 1 (`prisma/migrations/0001_init`).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum AgentStatus {
  IDLE
  WORKING
  BLOCKED
  OFFLINE
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum SprintStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(MEMBER)
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Agent {
  id            String       @id @default(cuid())
  name          String       @unique
  role          String
  status        AgentStatus  @default(IDLE)
  currentTaskId String?
  lastSeenAt    DateTime?
  messages      Message[]
  tasks         Task[]
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  assigneeId  String?
  sprintId    String?
  createdAt   DateTime   @default(now())
  completedAt DateTime?
  assignee    Agent?     @relation(fields: [assigneeId], references: [id])
  sprint      Sprint?    @relation(fields: [sprintId], references: [id])

  @@index([status])
  @@index([sprintId])
}

model Message {
  id          String   @id @default(cuid())
  fromAgentId String
  toAgentId   String?
  taskId      String?
  body        String
  createdAt   DateTime @default(now())
  from        Agent    @relation(fields: [fromAgentId], references: [id])

  @@index([createdAt])
}

model Sprint {
  id        String       @id @default(cuid())
  name      String
  goal      String?
  status    SprintStatus @default(ACTIVE)
  version   String?
  startedAt DateTime     @default(now())
  endedAt   DateTime?
  changelog String?
  tasks     Task[]
}

model WebhookKey {
  id           String    @id @default(cuid())
  name         String
  hashedSecret String
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
}

model EventLog {
  id         BigInt   @id @default(autoincrement())
  eventId    String   @unique
  type       String
  payload    Json
  receivedAt DateTime @default(now())
  streamId   String?

  @@index([receivedAt])
}
